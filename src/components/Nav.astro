---
import { NAV_LINKS, SITE } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur dark:border-border-dark dark:bg-bg-dark/80">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="text-sm font-semibold tracking-tight">
      {SITE.name}
    </a>

    <div class="flex items-center gap-3">
      <div class="hidden items-center gap-6 md:flex">
        {NAV_LINKS.map((link) => {
          const isActive = (link.href.replace(/\/$/, "") || "/") === currentPath;
          return (
            <a
              href={link.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "text-sm transition hover:text-accent dark:hover:text-accent-light",
                isActive ? "font-medium text-accent dark:text-accent-light" : "text-fg-muted dark:text-fg-dark-muted",
              ]}
            >
              {link.label}
            </a>
          );
        })}
      </div>

      <ThemeToggle />

      <button
        id="nav-toggle"
        type="button"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="flex h-9 w-9 items-center justify-center rounded-full border border-border md:hidden dark:border-border-dark"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4.5 w-4.5">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="nav-mobile" class="hidden flex-col gap-1 border-t border-border px-6 pb-4 md:hidden dark:border-border-dark">
    {NAV_LINKS.map((link) => (
      <a href={link.href} class="rounded px-2 py-2 text-sm text-fg-muted hover:bg-bg-subtle hover:text-accent dark:text-fg-dark-muted dark:hover:bg-bg-dark-subtle dark:hover:text-accent-light">
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const mobile = document.getElementById("nav-mobile");
  toggle?.addEventListener("click", () => {
    const isOpen = mobile?.classList.toggle("flex");
    mobile?.classList.toggle("hidden", !isOpen);
    toggle.setAttribute("aria-expanded", String(!!isOpen));
  });
</script>
