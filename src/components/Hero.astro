---
import HeroCanvas from "./HeroCanvas";
import { SITE } from "../data/site";
---

<section class="relative overflow-hidden">
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_70%_30%,var(--color-accent-soft),transparent_60%)] dark:bg-[radial-gradient(circle_at_70%_30%,color-mix(in_oklab,var(--color-accent)_18%,transparent),transparent_60%)]"
  >
  </div>

  <div class="mx-auto grid max-w-5xl items-center gap-10 px-6 py-20 md:grid-cols-2 md:py-28">
    <div>
      <p class="text-sm font-medium uppercase tracking-widest text-accent dark:text-accent-light">
        {SITE.roles.join(" · ")}
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight sm:text-5xl">
        {SITE.name}
      </h1>
      <p class="mt-6 max-w-md text-base text-fg-muted dark:text-fg-dark-muted">
        {SITE.description}
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/projects"
          class="rounded-full bg-accent px-6 py-3 text-sm font-medium text-white transition hover:bg-accent-strong"
        >
          View Projects
        </a>
        <a
          href="/resume"
          class="rounded-full border border-border px-6 py-3 text-sm font-medium transition hover:border-accent hover:text-accent dark:border-border-dark dark:hover:border-accent-light dark:hover:text-accent-light"
        >
          Resume
        </a>
      </div>
    </div>

    <div class="relative mx-auto aspect-square w-full max-w-sm">
      <HeroCanvas client:visible />
    </div>
  </div>
</section>
