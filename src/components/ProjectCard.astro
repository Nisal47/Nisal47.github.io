---
interface Props {
  slug: string;
  title: string;
  summary: string;
  role: string;
  tags: string[];
  cover?: string;
}

const { slug, title, summary, role, tags, cover } = Astro.props;
---

<a
  href={`/projects/${slug}`}
  class="group block overflow-hidden rounded-2xl border border-border transition hover:border-accent hover:shadow-sm dark:border-border-dark dark:hover:border-accent-light"
>
  {cover && (
    <img
      src={cover}
      alt={title}
      loading="lazy"
      class="aspect-video w-full object-cover"
    />
  )}
  <div class="p-6">
    <p class="text-xs font-medium uppercase tracking-widest text-accent dark:text-accent-light">{role}</p>
    <h3 class="mt-3 text-lg font-semibold tracking-tight group-hover:text-accent dark:group-hover:text-accent-light">
      {title}
    </h3>
    <p class="mt-2 text-sm text-fg-muted dark:text-fg-dark-muted">{summary}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent dark:bg-transparent dark:border dark:border-accent-light/40 dark:text-accent-light/90">
          {tag}
        </span>
      ))}
    </div>
  </div>
</a>
