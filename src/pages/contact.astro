---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../data/site";
---

<Layout title={`Contact — ${SITE.name}`}>
  <section class="mx-auto max-w-2xl px-6 py-16">
    <h1 class="text-3xl font-semibold tracking-tight">Contact</h1>
    <p class="mt-3 text-fg-muted dark:text-fg-dark-muted">
      The fastest way to reach me is by email.
    </p>

    <a
      href={`mailto:${SITE.email}`}
      class="mt-8 inline-block rounded-full bg-accent px-6 py-3 text-sm font-medium text-white transition hover:bg-accent-strong"
    >
      {SITE.email}
    </a>

    <div class="mt-10 flex gap-6 text-sm">
      {SITE.socials.github && (
        <a href={SITE.socials.github} target="_blank" rel="noreferrer" class="font-medium text-accent hover:underline dark:text-accent-light">
          GitHub
        </a>
      )}
      {SITE.socials.linkedin && (
        <a href={SITE.socials.linkedin} target="_blank" rel="noreferrer" class="font-medium text-accent hover:underline dark:text-accent-light">
          LinkedIn
        </a>
      )}
      {SITE.socials.scholar && (
        <a href={SITE.socials.scholar} target="_blank" rel="noreferrer" class="font-medium text-accent hover:underline dark:text-accent-light">
          Google Scholar
        </a>
      )}
    </div>
  </section>
</Layout>
