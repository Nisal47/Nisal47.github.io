---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../data/site";

const TOP_SKILLS = [
  "Human-Computer Interaction (HCI)",
  "UX Research & Design",
  "XR / Immersive Technologies",
  "Software Development (C# / Unity)",
  "Teaching & Research",
];
---

<Layout title={`About — ${SITE.name}`}>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <div class="flex flex-col items-start gap-8 sm:flex-row sm:items-center">
      <img
        src="/images/profile/headshot.jpg"
        alt={SITE.name}
        class="h-40 w-40 flex-shrink-0 rounded-full border border-border object-cover dark:border-border-dark sm:h-48 sm:w-48"
      />
      <div>
        <h1 class="text-3xl font-semibold tracking-tight">About</h1>
        <p class="mt-2 text-sm font-medium uppercase tracking-widest text-accent dark:text-accent-light">
          {SITE.roles.join(" · ")}
        </p>
      </div>
    </div>

    <div class="mt-10 space-y-6 text-base leading-relaxed text-fg-muted dark:text-fg-dark-muted">
      <p>
        I'm a tech enthusiast specialising in XR development, and I hold a PhD in Computer
        Science with a focus on HCI from Victoria University of Wellington. I bring years of
        experience across both academia and industry in New Zealand and Sri Lanka. My
        projects span virtual and augmented reality, building interactive experiences aimed
        at real problems in areas like medical health, heavy machinery operations, and
        education. What I enjoy most is bringing different technologies together to solve
        problems that actually matter in people's lives.
      </p>
    </div>

    <div class="mt-16">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-muted dark:text-fg-dark-muted">
        Top Skills
      </h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {TOP_SKILLS.map((skill) => (
          <li class="rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent dark:bg-transparent dark:border dark:border-accent-light/40 dark:text-accent-light/90">
            {skill}
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
