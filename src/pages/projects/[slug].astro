---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import VideoEmbed from "../../components/VideoEmbed.astro";
import { SITE } from "../../data/site";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  summary,
  role,
  tags,
  context,
  supervisors,
  problem,
  methods,
  outcome,
  demoUrl,
  repoUrl,
  videoUrl,
  cover,
  gallery,
  mediaNote,
} = project.data;
---

<Layout title={`${title} — ${SITE.name}`} description={summary}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <a href="/projects" class="text-sm font-medium text-accent hover:underline dark:text-accent-light">&larr; All projects</a>

    <p class="mt-6 text-xs font-medium uppercase tracking-widest text-accent dark:text-accent-light">{role}</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h1>
    <p class="mt-4 text-fg-muted dark:text-fg-dark-muted">{summary}</p>
    {context && <p class="mt-2 text-sm text-fg-muted dark:text-fg-dark-muted">{context}</p>}
    {supervisors.length > 0 && (
      <p class="mt-1 text-sm text-fg-muted dark:text-fg-dark-muted">
        Supervisors: {supervisors.join(", ")}
      </p>
    )}

    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent dark:bg-transparent dark:border dark:border-accent-light/40 dark:text-accent-light/90">
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-4 flex flex-wrap gap-4 text-sm">
      {demoUrl && <a href={demoUrl} class="font-medium text-accent hover:underline dark:text-accent-light">Live demo</a>}
      {repoUrl && <a href={repoUrl} class="font-medium text-accent hover:underline dark:text-accent-light">Repository</a>}
    </div>

    {cover && (
      <img
        src={cover}
        alt={title}
        class="mt-8 w-full rounded-2xl border border-border object-cover dark:border-border-dark"
      />
    )}
    {mediaNote && (
      <p class="mt-2 text-xs italic text-fg-muted dark:text-fg-dark-muted">{mediaNote}</p>
    )}

    {(problem?.length || methods?.length || outcome?.length) && (
      <div class="mt-10 grid gap-6 rounded-2xl border border-border p-6 sm:grid-cols-3 dark:border-border-dark">
        {problem?.length > 0 && (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-muted dark:text-fg-dark-muted">
              Problem
            </h2>
            <ul class="mt-2 list-disc space-y-1 pl-4 text-sm">
              {problem.map((p: string) => <li>{p}</li>)}
            </ul>
          </div>
        )}
        {methods?.length > 0 && (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-muted dark:text-fg-dark-muted">
              Methods
            </h2>
            <ul class="mt-2 list-disc space-y-1 pl-4 text-sm">
              {methods.map((m: string) => <li>{m}</li>)}
            </ul>
          </div>
        )}
        {outcome?.length > 0 && (
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-fg-muted dark:text-fg-dark-muted">
              Outcome
            </h2>
            <ul class="mt-2 list-disc space-y-1 pl-4 text-sm">
              {outcome.map((o: string) => <li>{o}</li>)}
            </ul>
          </div>
        )}
      </div>
    )}

    {videoUrl && (
      <div class="mt-10">
        <VideoEmbed url={videoUrl} />
      </div>
    )}

    <div class="prose prose-neutral mt-10 max-w-none dark:prose-invert prose-a:text-accent dark:prose-a:text-accent-light">
      <Content />
    </div>

    {gallery.length > 0 && (
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {gallery.map((item, i) => {
          const isLastOdd = gallery.length % 2 !== 0 && i === gallery.length - 1;
          return (
            <figure class:list={[isLastOdd && "sm:col-span-2"]}>
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="w-full rounded-2xl border border-border object-cover dark:border-border-dark"
              />
              {item.alt && (
                <figcaption class="mt-2 text-xs text-fg-muted dark:text-fg-dark-muted">
                  {item.alt}
                </figcaption>
              )}
            </figure>
          );
        })}
      </div>
    )}
  </article>
</Layout>
