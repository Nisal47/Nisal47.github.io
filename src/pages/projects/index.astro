---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { SITE } from "../../data/site";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const mainProjects = allProjects.filter((p) => !p.data.concept);
const conceptProjects = allProjects.filter((p) => p.data.concept);
---

<Layout title={`Projects — ${SITE.name}`}>
  <section class="mx-auto max-w-5xl px-6 py-16">
    <h1 class="text-3xl font-semibold tracking-tight">Projects</h1>
    <p class="mt-3 max-w-2xl text-fg-muted dark:text-fg-dark-muted">
      Case studies from UX research, XR development, and HCI work.
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {mainProjects.map((project) => (
        <ProjectCard
          slug={project.id}
          title={project.data.title}
          summary={project.data.summary}
          role={project.data.role}
          tags={project.data.tags}
          cover={project.data.cover}
        />
      ))}
    </div>

    {conceptProjects.length > 0 && (
      <div class="mt-20">
        <div class="border-t border-border pt-10 dark:border-border-dark">
          <h2 class="text-xl font-semibold tracking-tight">Concept Designs</h2>
          <p class="mt-2 max-w-2xl text-sm text-fg-muted dark:text-fg-dark-muted">
            Quick explorations and design tests, not part of the core portfolio.
          </p>
          <div class="mt-6 grid gap-6 sm:grid-cols-2">
            {conceptProjects.map((project) => (
              <ProjectCard
                slug={project.id}
                title={project.data.title}
                summary={project.data.summary}
                role={project.data.role}
                tags={project.data.tags}
                cover={project.data.cover}
              />
            ))}
          </div>
        </div>
      </div>
    )}
  </section>
</Layout>
