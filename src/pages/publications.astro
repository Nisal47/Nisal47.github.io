---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../data/site";

const publications = (await getCollection("publications")).sort((a, b) => b.data.year - a.data.year);

const typeLabel: Record<string, string> = {
  paper: "Paper",
  talk: "Talk",
  poster: "Poster",
  workshop: "Workshop",
};
---

<Layout title={`Publications — ${SITE.name}`}>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-semibold tracking-tight">Publications</h1>
    <p class="mt-3 text-fg-muted dark:text-fg-dark-muted">
      Papers, talks, and other research outputs.
    </p>

    <ul class="mt-10 divide-y divide-border dark:divide-border-dark">
      {publications.map((pub) => (
        <li class="py-5">
          <p class="text-xs font-medium uppercase tracking-widest text-accent dark:text-accent-light">
            {typeLabel[pub.data.type]} · {pub.data.year}
          </p>
          <h2 class="mt-2 text-base font-semibold tracking-tight">
            {pub.data.link ? (
              <a href={pub.data.link} target="_blank" rel="noreferrer" class="hover:text-accent dark:hover:text-accent-light">
                {pub.data.title}
              </a>
            ) : (
              pub.data.title
            )}
          </h2>
          <p class="mt-1 text-sm text-fg-muted dark:text-fg-dark-muted">
            {pub.data.authors} — {pub.data.venue}
          </p>
        </li>
      ))}
    </ul>
  </section>
</Layout>
